<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VULVAi — Digital Clinic</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --plum:#3D1A4A;--plum-mid:#5C2D6E;--plum-light:#7B3F8C;
  --magenta:#C4327A;--mag-pale:#F9E8F2;--mag-light:#E0559A;
  --navy:#0F1A2E;--navy-mid:#1A2A42;
  --teal:#0D7A6E;--teal-light:#E0F5F2;--teal-pale:#F0FAF9;
  --amber:#B45309;--amber-light:#FEF3C7;
  --green:#166534;--green-light:#DCFCE7;
  --surface:#F5F0F8;--lavender:#EDE4F2;--border:#E2D4EB;
  --text:#1A0A22;--text-mid:#4A3560;--text-muted:#9B82A8;
  --white:#fff;--cream:#FDFAF8;
}
body{font-family:'Helvetica Neue',Arial,sans-serif;background:#EDE0F5;min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:32px 20px 60px}

/* ── STORY PROGRESS BAR ── */
.story-bar{width:100%;max-width:960px;margin-bottom:28px}
.story-label{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--plum-mid);margin-bottom:10px;display:flex;align-items:center;justify-content:space-between}
.story-steps{display:flex;align-items:center;gap:0}
.story-step{display:flex;flex-direction:column;align-items:center;flex:1;position:relative}
.story-step:not(:last-child)::after{content:'';position:absolute;top:14px;left:50%;width:100%;height:2px;background:var(--border);z-index:0}
.story-step.done::after{background:var(--magenta)}
.story-step.active::after{background:linear-gradient(to right,var(--magenta),var(--border))}
.step-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;z-index:1;position:relative;transition:all .3s}
.step-dot-todo{background:var(--white);border:2px solid var(--border);color:var(--text-muted)}
.step-dot-active{background:var(--magenta);border:2px solid var(--magenta);color:#fff;box-shadow:0 0 0 4px rgba(196,50,122,.18)}
.step-dot-done{background:var(--magenta);border:2px solid var(--magenta);color:#fff}
.step-label{font-size:10px;font-weight:600;color:var(--text-muted);margin-top:5px;text-align:center;line-height:1.3}
.step-label.active{color:var(--magenta)}
.step-label.done{color:var(--plum-mid)}

/* ── ROLE BADGE ── */
.role-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;margin-bottom:16px}
.role-patient{background:var(--mag-pale);color:var(--magenta);border:1px solid rgba(196,50,122,.25)}
.role-doctor{background:var(--teal-light);color:var(--teal);border:1px solid rgba(13,122,110,.25)}
.role-dot{width:7px;height:7px;border-radius:50%}
.role-dot-patient{background:var(--magenta)}
.role-dot-doctor{background:var(--teal)}

/* ── CARD SHELL ── */
.card-shell{width:100%;max-width:960px;background:var(--white);border-radius:16px;overflow:hidden;box-shadow:0 8px 40px rgba(61,26,74,.13)}

/* ── SCREEN SYSTEM ── */
.screen{display:none}
.screen.active{display:block}

/* ── TOP CHROME ── */
.chrome{background:var(--plum);padding:14px 24px;display:flex;align-items:center;justify-content:space-between}
.chrome-logo{font-size:16px;font-weight:800;color:#fff;letter-spacing:-.2px}
.chrome-logo span{color:var(--magenta)}
.chrome-user{display:flex;align-items:center;gap:8px}
.chrome-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff}
.chrome-name{font-size:12px;font-weight:600;color:rgba(255,255,255,.75)}
.chrome-tag{font-size:9px;color:rgba(255,255,255,.45);margin-top:1px}

/* ── HERO SECTIONS ── */
.hero{background:linear-gradient(135deg,var(--plum) 0%,var(--plum-mid) 55%,var(--magenta) 130%);padding:28px 32px;color:#fff}
.hero-teal{background:linear-gradient(135deg,#0A2A24 0%,var(--teal) 130%);padding:28px 32px;color:#fff}
.hero-eye{font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:8px}
.hero-h{font-size:22px;font-weight:800;line-height:1.25;margin-bottom:8px}
.hero-sub{font-size:13px;color:rgba(255,255,255,.7);line-height:1.65;max-width:600px}
.hero-meta{display:flex;gap:20px;margin-top:14px}
.hero-stat{text-align:center}
.hero-stat-n{font-size:20px;font-weight:800}
.hero-stat-l{font-size:9px;color:rgba(255,255,255,.55);text-transform:uppercase;letter-spacing:.6px;margin-top:2px}

/* ── BODY ── */
.body{padding:28px 32px}
.body-sm{padding:20px 24px}

/* ── FORM ELEMENTS ── */
.field{margin-bottom:16px}
.field-label{font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text-muted);margin-bottom:6px}
.field-input{width:100%;padding:11px 14px;border-radius:8px;border:1.5px solid var(--border);font-size:13px;color:var(--text);background:var(--cream);outline:none;transition:border-color .15s}
.field-input:focus{border-color:var(--magenta)}
textarea.field-input{resize:vertical;min-height:80px;line-height:1.6}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}

/* ── SECTION LABEL ── */
.sec-label{font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--text-muted);display:flex;align-items:center;gap:8px;margin-bottom:12px}
.sec-label::after{content:'';flex:1;height:1px;background:var(--border)}

/* ── SYMPTOM CHIPS ── */
.chip-grid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
.chip{padding:8px 14px;border-radius:20px;border:1.5px solid var(--border);font-size:12px;color:var(--text-mid);cursor:pointer;transition:all .15s;background:var(--white)}
.chip:hover{border-color:var(--magenta);color:var(--magenta)}
.chip.on{background:var(--mag-pale);border-color:var(--magenta);color:var(--magenta);font-weight:600}

/* ── ANSWER OPTIONS ── */
.answer-opts{display:flex;flex-direction:column;gap:8px;margin-bottom:20px}
.answer-opt{padding:12px 16px;border-radius:10px;border:1.5px solid var(--border);font-size:13px;color:var(--text-mid);cursor:pointer;background:var(--white);transition:all .15s;text-align:left;width:100%}
.answer-opt:hover{border-color:var(--magenta);background:var(--mag-pale);color:var(--magenta)}
.answer-opt.selected{border-color:var(--magenta);background:var(--mag-pale);color:var(--magenta);font-weight:600}

/* ── PROGRESS BAR ── */
.quiz-prog{height:4px;background:var(--border);border-radius:2px;margin-bottom:20px}
.quiz-prog-fill{height:4px;border-radius:2px;background:var(--magenta);transition:width .3s}

/* ── DIFFERENTIAL CARDS ── */
.diff-cards{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.diff-card{border-radius:12px;border:1.5px solid var(--border);overflow:hidden}
.diff-card-header{display:flex;align-items:center;padding:12px 16px;gap:12px;background:var(--white)}
.diff-card.primary .diff-card-header{background:var(--mag-pale);border-bottom:1px solid rgba(196,50,122,.15)}
.diff-pct-bar{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.diff-pct-fill{height:6px;border-radius:3px;background:var(--magenta);transition:width .6s ease}
.diff-pct-fill.teal{background:var(--teal)}
.diff-pct-fill.amber{background:#F59E0B}
.diff-pct-num{font-size:14px;font-weight:800;color:var(--magenta);min-width:36px;text-align:right}
.diff-pct-num.teal{color:var(--teal)}
.diff-pct-num.amber{color:#F59E0B}
.diff-name{font-size:14px;font-weight:700;color:var(--text);min-width:260px}
.diff-body{padding:12px 16px;background:var(--cream);font-size:12px;color:var(--text-muted);line-height:1.65}

/* ── CHECKLIST ── */
.check-list{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.check-item{display:flex;align-items:flex-start;gap:12px;padding:10px 14px;border-radius:10px;background:var(--cream);border:1px solid var(--border)}
.check-item.done{background:var(--green-light);border-color:#86EFAC}
.check-circle{width:20px;height:20px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;margin-top:1px}
.check-circle.done{background:var(--green);border-color:var(--green);color:#fff}
.check-circle.active{border-color:var(--magenta);background:var(--mag-pale)}
.check-text{font-size:13px;color:var(--text-mid);line-height:1.5}
.check-text strong{color:var(--text)}

/* ── INFO CARDS ── */
.info-card{background:var(--lavender);border-radius:10px;padding:14px 16px;margin-bottom:12px}
.info-card-teal{background:var(--teal-pale);border-left:3px solid var(--teal);border-radius:0 10px 10px 0;padding:14px 16px;margin-bottom:12px}
.info-card h5{font-size:13px;font-weight:700;color:var(--text);margin-bottom:4px}
.info-card-teal h5{color:var(--teal)}
.info-card p,.info-card-teal p{font-size:12px;color:var(--text-muted);line-height:1.65}

/* ── RESULT CARDS ── */
.result-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
.result-card{background:var(--lavender);border-radius:10px;padding:14px 16px;text-align:center}
.result-n{font-size:24px;font-weight:800;color:var(--plum)}
.result-l{font-size:11px;color:var(--text-muted);margin-top:3px;line-height:1.4}

/* ── TREATMENT CARDS ── */
.tx-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
.tx-card{border-radius:10px;border:1px solid var(--border);padding:14px 16px;background:var(--white)}
.tx-tier{font-size:9px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--text-muted);margin-bottom:5px}
.tx-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:5px}
.tx-body{font-size:11.5px;color:var(--text-muted);line-height:1.6}

/* ── TRACKER ── */
.tracker-row{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.tracker-item{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--cream);border-radius:10px;border:1px solid var(--border)}
.tracker-label{font-size:13px;font-weight:600;color:var(--text)}
.tracker-dots{display:flex;gap:5px}
.tdot{width:28px;height:28px;border-radius:50%;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:var(--text-muted);cursor:pointer;transition:all .15s}
.tdot:hover{border-color:var(--magenta);color:var(--magenta)}
.tdot.on{background:var(--magenta);border-color:var(--magenta);color:#fff}

/* ── BUTTONS ── */
.btn{display:block;width:100%;padding:13px;background:var(--magenta);color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;text-align:center;transition:background .15s;margin-top:8px}
.btn:hover{background:#a8276a}
.btn-teal{background:var(--teal)}
.btn-teal:hover{background:#0a6860}
.btn-outline{background:transparent;border:2px solid var(--border);color:var(--text-mid);margin-top:8px}
.btn-outline:hover{border-color:var(--magenta);color:var(--magenta)}
.btn-sm{padding:9px 18px;font-size:12px;width:auto;display:inline-block}

/* ── PILLS ── */
.pill{display:inline-block;padding:4px 10px;border-radius:12px;font-size:10px;font-weight:700}
.pill-mag{background:var(--mag-pale);color:var(--magenta)}
.pill-teal{background:var(--teal-light);color:var(--teal)}
.pill-green{background:var(--green-light);color:var(--green)}
.pill-amber{background:var(--amber-light);color:var(--amber)}

/* ── DIVIDER ── */
.divider{height:1px;background:var(--border);margin:20px 0}

/* ── DOC HEADER ── */
.doc-header{display:flex;gap:16px;align-items:flex-start;padding:20px 24px;background:var(--teal-pale);border-bottom:1px solid rgba(13,122,110,.15)}
.doc-avatar{width:44px;height:44px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:#fff;flex-shrink:0}
.doc-name{font-size:15px;font-weight:700;color:var(--text)}
.doc-title{font-size:12px;color:var(--text-muted);margin-top:2px}
.doc-badge{margin-top:5px}

/* ── NOTE BOX ── */
.note-box{background:var(--cream);border:1.5px solid var(--border);border-radius:10px;padding:14px 16px;font-size:13px;color:var(--text-mid);line-height:1.7;margin-bottom:14px}
.note-box strong{color:var(--text)}

/* ── LAB TABLE ── */
.lab-table{width:100%;border-collapse:collapse;margin-bottom:16px}
.lab-table th{background:var(--surface);padding:8px 12px;font-size:11px;font-weight:700;color:var(--text-muted);text-align:left;border-bottom:1px solid var(--border)}
.lab-table td{padding:10px 12px;font-size:12.5px;color:var(--text-mid);border-bottom:1px solid var(--border)}
.lab-table tr:last-child td{border-bottom:none}
.lab-flag{font-size:10px;font-weight:700;padding:2px 6px;border-radius:6px}
.flag-low{background:#FEF3C7;color:#B45309}
.flag-normal{background:var(--green-light);color:var(--green)}
.flag-high{background:#FEE2E2;color:#991B1B}

/* ── DIAGNOSIS CONFIRM ── */
.dx-confirm{background:var(--mag-pale);border:1.5px solid rgba(196,50,122,.25);border-radius:12px;padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:16px}
.dx-confirm-icon{width:40px;height:40px;border-radius:50%;background:var(--magenta);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;color:#fff;font-weight:800}
.dx-confirm-label{font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--magenta);margin-bottom:3px}
.dx-confirm-name{font-size:15px;font-weight:800;color:var(--plum)}

/* ── PATIENT RESULT ── */
.result-hero{background:linear-gradient(135deg,var(--plum) 0%,var(--plum-mid) 55%,var(--magenta) 130%);padding:28px 32px;color:#fff}
.result-label{font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,.55);margin-bottom:6px}
.result-dx{font-size:20px;font-weight:800;margin-bottom:8px}
.result-sub{font-size:13px;color:rgba(255,255,255,.7);line-height:1.6}
.result-tags{display:flex;gap:8px;margin-top:12px;flex-wrap:wrap}
.result-tag{padding:4px 12px;border-radius:12px;font-size:11px;font-weight:700}

/* ── STEP NAV ── */
.step-nav{display:flex;justify-content:space-between;align-items:center;padding:16px 24px;border-top:1px solid var(--border);background:var(--cream)}
.step-nav-label{font-size:11px;color:var(--text-muted)}

/* ── LOADING ── */
.loading-screen{padding:60px 32px;text-align:center}
.loading-spinner{width:48px;height:48px;border-radius:50%;border:3px solid var(--border);border-top-color:var(--magenta);animation:spin .8s linear infinite;margin:0 auto 20px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-h{font-size:18px;font-weight:700;color:var(--text);margin-bottom:8px}
.loading-p{font-size:13px;color:var(--text-muted);line-height:1.6}

/* ── TRANSITION ── */
.transition-screen{padding:40px 32px;text-align:center}
.transition-icon{width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 16px}
.transition-icon-teal{background:var(--teal-light)}
.transition-icon-mag{background:var(--mag-pale)}
.transition-h{font-size:20px;font-weight:800;color:var(--text);margin-bottom:8px}
.transition-p{font-size:13px;color:var(--text-muted);line-height:1.65;max-width:480px;margin:0 auto 24px}

/* ── ANIMATIONS ── */
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.screen.active{animation:fadeIn .25s ease}
</style>
</head>
<body>

<!-- STORY PROGRESS -->
<div class="story-bar">
  <div class="story-label">
    <span>VULVAi · Digital Clinic Demo</span>
    <span id="step-counter" style="color:var(--text-muted)">Step 1 of 7</span>
  </div>
  <div class="story-steps">
    <div class="story-step active" id="dot-1"><div class="step-dot step-dot-active">1</div><div class="step-label active">Patient<br>intake</div></div>
    <div class="story-step" id="dot-2"><div class="step-dot step-dot-todo">2</div><div class="step-label">Symptom<br>quiz</div></div>
    <div class="story-step" id="dot-3"><div class="step-dot step-dot-todo">3</div><div class="step-label">Doctor<br>pre-visit</div></div>
    <div class="story-step" id="dot-4"><div class="step-dot step-dot-todo">4</div><div class="step-label">Exam &<br>diagnosis</div></div>
    <div class="story-step" id="dot-5"><div class="step-dot step-dot-todo">5</div><div class="step-label">Treatment<br>plan</div></div>
    <div class="story-step" id="dot-6"><div class="step-dot step-dot-todo">6</div><div class="step-label">Patient<br>results</div></div>
    <div class="story-step" id="dot-7"><div class="step-dot step-dot-todo">7</div><div class="step-label">Tracking<br>& follow-up</div></div>
  </div>
</div>

<div class="card-shell">

<!-- ════════════════════════════════════════════
     SCREEN 1 — PATIENT INTAKE
════════════════════════════════════════════ -->
<div class="screen active" id="s1">
  <div class="chrome">
    <div class="chrome-logo">VULV<span>Ai</span></div>
    <div class="chrome-user">
      <div class="chrome-avatar" style="background:var(--magenta)">SJ</div>
      <div><div class="chrome-name">Sarah Johnson</div><div class="chrome-tag">Patient portal</div></div>
    </div>
  </div>
  <div class="hero">
    <div class="hero-eye">Patient intake</div>
    <div class="hero-h">Before your visit, tell us what's been happening</div>
    <div class="hero-sub">Your answers build a clinical brief for your doctor — so you spend your visit getting answers, not explaining your history from scratch.</div>
  </div>
  <div class="body">
    <div class="sec-label">About you</div>
    <div class="field-row" style="margin-bottom:16px">
      <div class="field"><div class="field-label">Full name</div><input class="field-input" value="Sarah Johnson" readonly></div>
      <div class="field"><div class="field-label">Date of birth</div><input class="field-input" value="March 14, 1996 (28 yrs)" readonly></div>
    </div>
    <div class="field-row" style="margin-bottom:16px">
      <div class="field"><div class="field-label">Current contraception</div><input class="field-input" value="Combined oral contraceptive pill — 3 years" readonly></div>
      <div class="field"><div class="field-label">Primary concern</div><input class="field-input" value="Recurrent urinary tract infections" readonly></div>
    </div>
    <div class="sec-label">Your symptoms — select all that apply</div>
    <div class="chip-grid">
      <div class="chip on">Burning with urination</div>
      <div class="chip on">Urinary urgency</div>
      <div class="chip on">Urinary frequency</div>
      <div class="chip on">Vulvar burning or pain</div>
      <div class="chip on">Pain with intercourse</div>
      <div class="chip">Pelvic pressure</div>
      <div class="chip on">Negative urine cultures</div>
      <div class="chip">Discharge</div>
      <div class="chip">Bladder pressure</div>
    </div>
    <div class="field"><div class="field-label">Duration of symptoms</div><input class="field-input" value="14 months" readonly></div>
    <div class="field"><div class="field-label">Prior treatments</div><input class="field-input" value="7 courses of antibiotics — nitrofurantoin ×4, trimethoprim-sulfamethoxazole ×3" readonly></div>
    <div class="field"><div class="field-label">What would you like your doctor to know?</div><textarea class="field-input" readonly>The antibiotics work for about 2–3 weeks and then the burning comes back. My cultures are negative half the time. My GYN keeps telling me it's UTIs but I feel like something else is going on. I just want answers.</textarea></div>
    <button class="btn" onclick="go(2)">Submit intake & begin symptom assessment →</button>
  </div>
</div>

<!-- ════════════════════════════════════════════
     SCREEN 2 — SYMPTOM QUIZ
════════════════════════════════════════════ -->
<div class="screen" id="s2">
  <div class="chrome">
    <div class="chrome-logo">VULV<span>Ai</span></div>
    <div class="chrome-user">
      <div class="chrome-avatar" style="background:var(--magenta)">SJ</div>
      <div><div class="chrome-name">Sarah Johnson</div><div class="chrome-tag">Patient portal</div></div>
    </div>
  </div>
  <div class="hero">
    <div class="hero-eye">Symptom assessment · 5 questions</div>
    <div class="hero-h">Let's map your symptoms precisely</div>
    <div class="hero-sub">Your answers teach our algorithm to distinguish between conditions that look identical on the surface.</div>
  </div>
  <div class="body">
